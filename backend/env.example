PORT=5001
# Primary database (Neon PostgreSQL)
NEON_DB_URI=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Optional: only needed for legacy scripts (e.g. migrate:subscriptions backfill) that still use Mongo

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=your_cloudinary_url

TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Must pass backend/utils/authSecurity.js (>=32 bytes, entropy, unique chars). Dev-only example — use a unique value in production (e.g. openssl rand -hex 32).
JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
SMTP_PASS=your_smtp_password
SMTP_HOST=your_smtp_host
SMTP_PORT=your_smtp_port
SMTP_SECURE=false
SMTP_USER=your_smtp_user
EMAIL_FROM="Your Name <your_email@example.com>"
