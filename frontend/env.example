NEXT_PUBLIC_API_URL=http://localhost:5001/api
# Same rules as backend JWT_SECRET (use openssl rand -hex 32 for a fresh value).
JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Required for Next.js wallet API routes (same Neon DB as backend)
NEON_DB_URI=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Optional: legacy Mongo (e.g. moderation backfill script only)
# MONGODB_URI=your_mongodb_connection_string
